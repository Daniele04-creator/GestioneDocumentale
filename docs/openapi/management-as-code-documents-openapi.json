    "/api/v1/document-keys/{keyType}/{key}/documents/{documentId}/versions/{version}/file": {
      "get": {
        "tags": [
          "Document keys"
        ],
        "summary": "Download document version file",
        "description": "Scarica il file associato a una versione storica del documento.",
        "operationId": "DocumentKeysController_downloadDocumentVersionFile",
        "parameters": [
          {
            "name": "keyType",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "example": "project"
            },
            "description": "Tipo del contenitore documentale"
          },
          {
            "name": "key",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "example": "PRJ-001"
            },
            "description": "Identificativo del contenitore documentale"
          },
          {
            "name": "documentId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "pattern": "^DOC-[0-9]{3,}$",
              "example": "DOC-001"
            },
            "description": "ID del documento"
          },
          {
            "name": "version",
            "required": true,
            "in": "path",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "example": 1
            },
            "description": "Versione storica del documento"
          }
        ],
        "responses": {
          "200": {
            "description": "Version file stream.",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "text/plain": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Invalid document id or version.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "INVALID_DOCUMENT_ID": {
                    "summary": "INVALID_DOCUMENT_ID",
                    "value": {
                      "code": "INVALID_DOCUMENT_ID",
                      "message": "Invalid document id."
                    }
                  },
                  "INVALID_QUERY_PARAM": {
                    "summary": "INVALID_QUERY_PARAM",
                    "value": {
                      "code": "INVALID_QUERY_PARAM",
                      "message": "Invalid document version."
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Key, document, version or file not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "KEY_NOT_FOUND": {
                    "summary": "KEY_NOT_FOUND",
                    "value": {
                      "code": "KEY_NOT_FOUND",
                      "message": "Document key not found."
                    }
                  },
                  "DOCUMENT_NOT_FOUND": {
                    "summary": "DOCUMENT_NOT_FOUND",
                    "value": {
                      "code": "DOCUMENT_NOT_FOUND",
                      "message": "Document not found."
                    }
                  },
                  "DOCUMENT_FILE_NOT_FOUND": {
                    "summary": "DOCUMENT_FILE_NOT_FOUND",
                    "value": {
                      "code": "DOCUMENT_FILE_NOT_FOUND",
                      "message": "Document file not found."
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "info": {
    "title": "Management as Code Documents API",
    "description": "API del modulo documentale key-scoped di Management as Code.",
    "version": "0.1.0",
    "contact": {}
