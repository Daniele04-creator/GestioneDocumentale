{
  "openapi": "3.0.0",
  "paths": {
    "/api/v1/health": {
      "get": {
        "description": "Verifica che il backend sia avviato.",
        "operationId": "HealthController_getHealth",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Backend is running.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        },
        "summary": "Health check",
        "tags": [
          "Health"
        ]
      }
    },
    "/api/v1/document-keys/{keyType}/{key}/document-tree": {
      "get": {
        "description": "Restituisce una struttura leggera dei subKey del contenitore documentale, con conteggi e statusSummary, senza caricare i dettagli dei documenti.",
        "operationId": "DocumentKeysController_getDocumentTree",
        "parameters": [
          {
            "name": "keyType",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "example": "project"
            },
            "description": "Tipo del contenitore documentale"
          },
          {
            "name": "key",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "example": "PRJ-001"
            },
            "description": "Identificativo del contenitore documentale"
          }
        ],
        "responses": {
          "200": {
            "description": "Document tree returned.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentTreeResponse"
                }
              }
            }
          },
          "404": {
            "description": "KEY_NOT_FOUND",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "KEY_NOT_FOUND": {
                    "summary": "KEY_NOT_FOUND",
                    "value": {
                      "code": "KEY_NOT_FOUND",
                      "message": "Document key not found."
                    }
                  }
                }
              }
            }
          }
        },
        "summary": "Get document tree by key",
        "tags": [
          "Document keys"
        ]
      }
    },
    "/api/v1/document-keys/{keyType}/{key}/documents": {
      "get": {
        "description": "Restituisce i documenti del contenitore documentale, raggruppati per subKey e filtrabili tramite query parameters.",
        "operationId": "DocumentKeysController_listDocuments",
        "parameters": [
          {
            "name": "search",
            "required": false,
            "in": "query",
            "schema": {
              "example": "srs"
            }
          },
          {
            "name": "status",
            "required": false,
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "draft",
                "in_review",
                "approved",
                "archived"
              ],
              "example": "approved"
            }
          },
          {
            "name": "tag",
            "required": false,
            "in": "query",
            "schema": {
              "example": "Architettura"
            }
          },
          {
            "name": "ownerId",
            "required": false,
            "in": "query",
            "schema": {
              "example": "owner-001"
            }
          },
          {
            "name": "subKey",
            "required": false,
            "in": "query",
            "schema": {
              "example": "PKG-001"
            }
          },
          {
            "name": "keyType",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "example": "project"
            },
            "description": "Tipo del contenitore documentale"
          },
          {
            "name": "key",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "example": "PRJ-001"
            },
            "description": "Identificativo del contenitore documentale"
          }
        ],
        "responses": {
          "200": {
            "description": "Document home returned.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentHomeResponse"
                }
              }
            }
          },
          "400": {
            "description": "INVALID_QUERY_PARAM",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "INVALID_QUERY_PARAM": {
                    "summary": "INVALID_QUERY_PARAM",
                    "value": {
                      "code": "INVALID_QUERY_PARAM",
                      "message": "Parametro query non valido."
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "KEY_NOT_FOUND",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "KEY_NOT_FOUND": {
                    "summary": "KEY_NOT_FOUND",
                    "value": {
                      "code": "KEY_NOT_FOUND",
                      "message": "Document key not found."
                    }
                  }
                }
              }
            }
          }
        },
        "summary": "List documents by key",
        "tags": [
          "Document keys"
        ]
      }
    },
    "/api/v1/document-keys/{keyType}/{key}/documents/{documentId}/file": {
      "get": {
        "description": "Scarica il file associato al documento.",
        "operationId": "DocumentKeysController_downloadDocumentFile",
        "parameters": [
          {
            "name": "keyType",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "example": "project"
            },
            "description": "Tipo del contenitore documentale"
          },
          {
            "name": "key",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "example": "PRJ-001"
            },
            "description": "Identificativo del contenitore documentale"
          },
          {
            "name": "documentId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "pattern": "^DOC-[0-9]{3}$",
              "example": "DOC-001"
            },
            "description": "ID del documento nel formato DOC-001"
          }
        ],
        "responses": {
          "200": {
            "description": "File binario o testuale associato al documento.",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "INVALID_DOCUMENT_ID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "INVALID_DOCUMENT_ID": {
                    "summary": "INVALID_DOCUMENT_ID",
                    "value": {
                      "code": "INVALID_DOCUMENT_ID",
                      "message": "Invalid document id."
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "KEY_NOT_FOUND, DOCUMENT_NOT_FOUND or DOCUMENT_FILE_NOT_FOUND",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "KEY_NOT_FOUND": {
                    "summary": "KEY_NOT_FOUND",
                    "value": {
                      "code": "KEY_NOT_FOUND",
                      "message": "Document key not found."
                    }
                  },
                  "DOCUMENT_NOT_FOUND": {
                    "summary": "DOCUMENT_NOT_FOUND",
                    "value": {
                      "code": "DOCUMENT_NOT_FOUND",
                      "message": "Document not found."
                    }
                  },
                  "DOCUMENT_FILE_NOT_FOUND": {
                    "summary": "DOCUMENT_FILE_NOT_FOUND",
                    "value": {
                      "code": "DOCUMENT_FILE_NOT_FOUND",
                      "message": "Document file not found."
                    }
                  }
                }
              }
            }
          }
        },
        "summary": "Download document file by key",
        "tags": [
          "Document keys"
        ]
      }
    },
    "/api/v1/document-keys/{keyType}/{key}/documents/{documentId}": {
      "get": {
        "description": "Restituisce il dettaglio di un documento appartenente al contenitore documentale indicato.",
        "operationId": "DocumentKeysController_getDocumentById",
        "parameters": [
          {
            "name": "keyType",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "example": "project"
            },
            "description": "Tipo del contenitore documentale"
          },
          {
            "name": "key",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "example": "PRJ-001"
            },
            "description": "Identificativo del contenitore documentale"
          },
          {
            "name": "documentId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "pattern": "^DOC-[0-9]{3}$",
              "example": "DOC-001"
            },
            "description": "ID del documento nel formato DOC-001"
          }
        ],
        "responses": {
          "200": {
            "description": "Document detail returned.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentDetailResponse"
                }
              }
            }
          },
          "400": {
            "description": "INVALID_DOCUMENT_ID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "INVALID_DOCUMENT_ID": {
                    "summary": "INVALID_DOCUMENT_ID",
                    "value": {
                      "code": "INVALID_DOCUMENT_ID",
                      "message": "Invalid document id."
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "KEY_NOT_FOUND or DOCUMENT_NOT_FOUND",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "KEY_NOT_FOUND": {
                    "summary": "KEY_NOT_FOUND",
                    "value": {
                      "code": "KEY_NOT_FOUND",
                      "message": "Document key not found."
                    }
                  },
                  "DOCUMENT_NOT_FOUND": {
                    "summary": "DOCUMENT_NOT_FOUND",
                    "value": {
                      "code": "DOCUMENT_NOT_FOUND",
                      "message": "Document not found."
                    }
                  }
                }
              }
            }
          }
        },
        "summary": "Get document by id and key",
        "tags": [
          "Document keys"
        ]
      },
      "patch": {
        "description": "Aggiorna i campi modificabili di un documento non archiviato.",
        "operationId": "DocumentKeysController_updateDocument",
        "parameters": [
          {
            "name": "keyType",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "example": "project"
            },
            "description": "Tipo del contenitore documentale"
          },
          {
            "name": "key",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "example": "PRJ-001"
            },
            "description": "Identificativo del contenitore documentale"
          },
          {
            "name": "documentId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "pattern": "^DOC-[0-9]{3}$",
              "example": "DOC-001"
            },
            "description": "ID del documento nel formato DOC-001"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateDocumentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated document detail returned.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentDetailResponse"
                }
              }
            }
          },
          "400": {
            "description": "INVALID_DOCUMENT_ID or INVALID_DOCUMENT_PATCH",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "INVALID_DOCUMENT_ID": {
                    "summary": "INVALID_DOCUMENT_ID",
                    "value": {
                      "code": "INVALID_DOCUMENT_ID",
                      "message": "Invalid document id."
                    }
                  },
                  "INVALID_DOCUMENT_PATCH": {
                    "summary": "INVALID_DOCUMENT_PATCH",
                    "value": {
                      "code": "INVALID_DOCUMENT_PATCH",
                      "message": "Invalid document patch."
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "KEY_NOT_FOUND or DOCUMENT_NOT_FOUND",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "KEY_NOT_FOUND": {
                    "summary": "KEY_NOT_FOUND",
                    "value": {
                      "code": "KEY_NOT_FOUND",
                      "message": "Document key not found."
                    }
                  },
                  "DOCUMENT_NOT_FOUND": {
                    "summary": "DOCUMENT_NOT_FOUND",
                    "value": {
                      "code": "DOCUMENT_NOT_FOUND",
                      "message": "Document not found."
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "DOCUMENT_ARCHIVED",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "DOCUMENT_ARCHIVED": {
                    "summary": "DOCUMENT_ARCHIVED",
                    "value": {
                      "code": "DOCUMENT_ARCHIVED",
                      "message": "Il documento archiviato non puo' essere modificato."
                    }
                  }
                }
              }
            }
          }
        },
        "summary": "Update document by key",
        "tags": [
          "Document keys"
        ]
      },
      "delete": {
        "description": "Archivia logicamente il documento impostando status archived e archivedAt.",
        "operationId": "DocumentKeysController_archiveDocument",
        "parameters": [
          {
            "name": "keyType",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "example": "project"
            },
            "description": "Tipo del contenitore documentale"
          },
          {
            "name": "key",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "example": "PRJ-001"
            },
            "description": "Identificativo del contenitore documentale"
          },
          {
            "name": "documentId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "pattern": "^DOC-[0-9]{3}$",
              "example": "DOC-001"
            },
            "description": "ID del documento nel formato DOC-001"
          }
        ],
        "responses": {
          "200": {
            "description": "Archived document detail returned.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentDetailResponse"
                }
              }
            }
          },
          "400": {
            "description": "INVALID_DOCUMENT_ID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "INVALID_DOCUMENT_ID": {
                    "summary": "INVALID_DOCUMENT_ID",
                    "value": {
                      "code": "INVALID_DOCUMENT_ID",
                      "message": "Invalid document id."
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "KEY_NOT_FOUND or DOCUMENT_NOT_FOUND",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "KEY_NOT_FOUND": {
                    "summary": "KEY_NOT_FOUND",
                    "value": {
                      "code": "KEY_NOT_FOUND",
                      "message": "Document key not found."
                    }
                  },
                  "DOCUMENT_NOT_FOUND": {
                    "summary": "DOCUMENT_NOT_FOUND",
                    "value": {
                      "code": "DOCUMENT_NOT_FOUND",
                      "message": "Document not found."
                    }
                  }
                }
              }
            }
          }
        },
        "summary": "Archive document by key",
        "tags": [
          "Document keys"
        ]
      }
    }
  },
  "info": {
    "title": "Management as Code Documents API",
    "description": "API del modulo documentale key-scoped di Management as Code.",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "Document keys",
      "description": ""
    },
    {
      "name": "Health",
      "description": ""
    }
  ],
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development server"
    }
  ],
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "required": [
          "status",
          "timestamp"
        ],
        "properties": {
          "status": {
            "type": "string",
            "example": "ok"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "example": "2026-01-01T10:00:00.000Z"
          }
        }
      },
      "ApiError": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string",
            "example": "ERROR_CODE"
          },
          "message": {
            "type": "string",
            "example": "Clear error message."
          }
        }
      },
      "DocumentStatusSummary": {
        "type": "object",
        "required": [
          "draft",
          "in_review",
          "approved",
          "archived"
        ],
        "properties": {
          "draft": {
            "type": "integer",
            "minimum": 0,
            "example": 0
          },
          "in_review": {
            "type": "integer",
            "minimum": 0,
            "example": 0
          },
          "approved": {
            "type": "integer",
            "minimum": 0,
            "example": 1
          },
          "archived": {
            "type": "integer",
            "minimum": 0,
            "example": 0
          }
        }
      },
      "DocumentTag": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "example": "Architettura"
          }
        }
      },
      "DocumentOwner": {
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "owner-001"
          },
          "name": {
            "type": "string",
            "example": "Francesca R"
          }
        }
      },
      "KeyRef": {
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "PRJ-001"
          },
          "name": {
            "type": "string",
            "example": "Management as Code Demo"
          }
        }
      },
      "ParentSubKeyRef": {
        "type": "object",
        "nullable": true,
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "PKG-001"
          },
          "name": {
            "type": "string",
            "example": "Documentazione requisiti"
          }
        },
        "example": null
      },
      "SubKeyRef": {
        "type": "object",
        "required": [
          "id",
          "name",
          "parentSubKey"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "PKG-001"
          },
          "name": {
            "type": "string",
            "example": "Documentazione requisiti"
          },
          "parentSubKey": {
            "$ref": "#/components/schemas/ParentSubKeyRef"
          }
        }
      },
      "FileInfo": {
        "type": "object",
        "required": [
          "fileName",
          "mimeType",
          "sizeBytes"
        ],
        "properties": {
          "fileName": {
            "type": "string",
            "example": "document-key-plan.txt"
          },
          "mimeType": {
            "type": "string",
            "example": "text/plain"
          },
          "sizeBytes": {
            "type": "integer",
            "minimum": 0,
            "example": 136
          }
        }
      },
      "DocumentListItem": {
        "type": "object",
        "required": [
          "id",
          "title",
          "status",
          "version",
          "updatedAt",
          "owner",
          "tags"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "DOC-001"
          },
          "title": {
            "type": "string",
            "example": "Specifica SRS"
          },
          "description": {
            "type": "string",
            "example": "Documento dei requisiti software"
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "in_review",
              "approved",
              "archived"
            ],
            "example": "approved"
          },
          "version": {
            "type": "integer",
            "minimum": 1,
            "example": 1
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "example": null
          },
          "owner": {
            "$ref": "#/components/schemas/DocumentOwner"
          },
          "tags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DocumentTag"
            }
          }
        }
      },
      "DocumentDetail": {
        "type": "object",
        "required": [
          "id",
          "title",
          "status",
          "keyType",
          "key",
          "subKey",
          "owner",
          "fileInfo",
          "version",
          "createdAt",
          "updatedAt",
          "archivedAt",
          "tags"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "DOC-001"
          },
          "title": {
            "type": "string",
            "example": "Specifica SRS"
          },
          "description": {
            "type": "string",
            "example": "Documento dei requisiti software"
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "in_review",
              "approved",
              "archived"
            ],
            "example": "approved"
          },
          "version": {
            "type": "integer",
            "minimum": 1,
            "example": 1
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "example": null
          },
          "owner": {
            "$ref": "#/components/schemas/DocumentOwner"
          },
          "tags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DocumentTag"
            }
          },
          "keyType": {
            "type": "string",
            "example": "project"
          },
          "key": {
            "$ref": "#/components/schemas/KeyRef"
          },
          "subKey": {
            "$ref": "#/components/schemas/SubKeyRef"
          },
          "fileInfo": {
            "$ref": "#/components/schemas/FileInfo"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-01-01T10:00:00.000Z"
          },
          "archivedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "example": null
          }
        }
      },
      "DocumentDetailResponse": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/DocumentDetail"
          }
        }
      },
      "DocumentSubKeyGroup": {
        "type": "object",
        "required": [
          "keyType",
          "key",
          "subKey",
          "documentCount",
          "statusSummary",
          "documents"
        ],
        "properties": {
          "keyType": {
            "type": "string",
            "example": "project"
          },
          "key": {
            "$ref": "#/components/schemas/KeyRef"
          },
          "subKey": {
            "$ref": "#/components/schemas/SubKeyRef"
          },
          "documentCount": {
            "type": "integer",
            "minimum": 0,
            "example": 2
          },
          "statusSummary": {
            "$ref": "#/components/schemas/DocumentStatusSummary"
          },
          "documents": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DocumentListItem"
            }
          }
        }
      },
      "DocumentHomeMeta": {
        "type": "object",
        "required": [
          "totalSubKeys",
          "totalDocuments"
        ],
        "properties": {
          "totalSubKeys": {
            "type": "integer",
            "minimum": 0,
            "example": 1
          },
          "totalDocuments": {
            "type": "integer",
            "minimum": 0,
            "example": 2
          }
        }
      },
      "DocumentHomeResponse": {
        "type": "object",
        "required": [
          "data",
          "meta"
        ],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DocumentSubKeyGroup"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/DocumentHomeMeta"
          }
        }
      },
      "DocumentTreeSubKey": {
        "type": "object",
        "required": [
          "keyType",
          "key",
          "subKey",
          "documentCount",
          "statusSummary"
        ],
        "properties": {
          "keyType": {
            "type": "string",
            "example": "project"
          },
          "key": {
            "$ref": "#/components/schemas/KeyRef"
          },
          "subKey": {
            "$ref": "#/components/schemas/SubKeyRef"
          },
          "documentCount": {
            "type": "integer",
            "minimum": 0,
            "example": 2
          },
          "statusSummary": {
            "$ref": "#/components/schemas/DocumentStatusSummary"
          }
        }
      },
      "DocumentTreeMeta": {
        "type": "object",
        "required": [
          "totalSubKeys",
          "totalDocuments"
        ],
        "properties": {
          "totalSubKeys": {
            "type": "integer",
            "minimum": 0,
            "example": 1
          },
          "totalDocuments": {
            "type": "integer",
            "minimum": 0,
            "example": 2
          }
        }
      },
      "DocumentTreeResponse": {
        "type": "object",
        "required": [
          "data",
          "meta"
        ],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DocumentTreeSubKey"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/DocumentTreeMeta"
          }
        }
      },
      "UpdateDocumentRequest": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": {
            "type": "string",
            "example": "Nuovo titolo"
          },
          "description": {
            "type": "string",
            "example": "Nuova descrizione"
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "in_review",
              "approved"
            ],
            "example": "in_review"
          }
        }
      }
    }
  }
}
