{
  "openapi": "3.0.0",
  "paths": {
    "/api/v1/health": {
      "get": {
        "description": "Verifica che il backend sia avviato.",
        "operationId": "HealthController_getHealth",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Backend is running.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        },
        "summary": "Health check",
        "tags": [
          "Health"
        ]
      }
    },
    "/api/v1/document-keys/{keyType}/{key}/document-tree": {
      "get": {
        "description": "Restituisce una struttura leggera dei subKey, dove subKey rappresenta WorkPackage.id del MAC core, con conteggi e statusSummary.",
        "operationId": "DocumentKeysController_getDocumentTree",
        "parameters": [
          {
            "name": "keyType",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "example": "Project",
              "enum": [
                "Portfolio",
                "Program",
                "Project",
                "Activity",
                "Template",
                "Join"
              ],
              "description": "Tipo item MAC core compatibile con ItemType."
            },
            "description": "Tipo item MAC core. Valori compatibili con ItemType: Portfolio, Program, Project, Activity, Template, Join."
          },
          {
            "name": "key",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "example": "PRJ-001"
            },
            "description": "Identificativo dell item MAC core, equivalente a itemId."
          }
        ],
        "responses": {
          "200": {
            "description": "Document tree returned.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentTreeResponse"
                }
              }
            }
          },
          "404": {
            "description": "KEY_NOT_FOUND",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "KEY_NOT_FOUND": {
                    "summary": "KEY_NOT_FOUND",
                    "value": {
                      "code": "KEY_NOT_FOUND",
                      "message": "Document key not found."
                    }
                  }
                }
              }
            }
          }
        },
        "summary": "Get document tree by key",
        "tags": [
          "Document keys"
        ]
      }
    },
    "/api/v1/document-keys/{keyType}/{key}/documents": {
      "get": {
        "description": "Restituisce i documenti del contenitore documentale, raggruppati per subKey. keyType/key mappano ItemType/itemId MAC core; subKey mappa WorkPackage.id. La ricerca documentale avviene tramite tag.",
        "operationId": "DocumentKeysController_listDocuments",
        "parameters": [
          {
            "name": "status",
            "required": false,
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "draft",
                "in_review",
                "approved",
                "archived"
              ],
              "example": "approved"
            },
            "description": "Filtro tecnico per stato documento."
          },
          {
            "name": "tag",
            "required": false,
            "in": "query",
            "schema": {
              "example": "Architettura"
            },
            "description": "Nome tag usato come criterio di ricerca documentale case-insensitive."
          },
          {
            "name": "subKey",
            "required": false,
            "in": "query",
            "schema": {
              "example": "WP-001",
              "type": "string"
            },
            "description": "Filtra per WorkPackage.id del contesto MAC core."
          },
          {
            "name": "keyType",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "example": "Project",
              "enum": [
                "Portfolio",
                "Program",
                "Project",
                "Activity",
                "Template",
                "Join"
              ],
              "description": "Tipo item MAC core compatibile con ItemType."
            },
            "description": "Tipo item MAC core. Valori compatibili con ItemType: Portfolio, Program, Project, Activity, Template, Join."
          },
          {
            "name": "key",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "example": "PRJ-001"
            },
            "description": "Identificativo dell item MAC core, equivalente a itemId."
          }
        ],
        "responses": {
          "200": {
            "description": "Document home returned.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentHomeResponse"
                }
              }
            }
          },
          "400": {
            "description": "INVALID_QUERY_PARAM",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "INVALID_QUERY_PARAM": {
                    "summary": "INVALID_QUERY_PARAM",
                    "value": {
                      "code": "INVALID_QUERY_PARAM",
                      "message": "Parametro query non valido."
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "KEY_NOT_FOUND",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "KEY_NOT_FOUND": {
                    "summary": "KEY_NOT_FOUND",
                    "value": {
                      "code": "KEY_NOT_FOUND",
                      "message": "Document key not found."
                    }
                  }
                }
              }
            }
          }
        },
        "summary": "List documents by key",
        "tags": [
          "Document keys"
        ]
      },
      "post": {
        "description": "Acquisisce un documento finale prodotto da un modulo esterno e lo collega al contesto MAC keyType/key/subKey. keyType e key corrispondono a ItemType e itemId; subKey corrisponde a WorkPackage.id.",
        "operationId": "DocumentKeysController_createDocument",
        "parameters": [
          {
            "name": "keyType",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "example": "Project",
              "enum": [
                "Portfolio",
                "Program",
                "Project",
                "Activity",
                "Template",
                "Join"
              ],
              "description": "Tipo item MAC core compatibile con ItemType."
            },
            "description": "Tipo item MAC core. Valori compatibili con ItemType: Portfolio, Program, Project, Activity, Template, Join."
          },
          {
            "name": "key",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "example": "PRJ-001"
            },
            "description": "Identificativo dell item MAC core, equivalente a itemId."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/CreateDocumentRequest"
              },
              "examples": {
                "createDocument": {
                  "summary": "Acquire generated document",
                  "value": {
                    "file": "<binary file>",
                    "subKey": "WP-001",
                    "documentKey": "TPL-REPORT-MENSILE-2026-01",
                    "metadata": "{\"title\":\"Report avanzamento\",\"description\":\"Documento prodotto da una funzione esterna\",\"templateId\":\"TPL-REPORT-MENSILE\",\"templateName\":\"Template report mensile\",\"owner\":{\"id\":\"USR-123\",\"name\":\"Mario Rossi\",\"source\":\"external-user-service\"}}",
                    "status": "draft",
                    "tags": [
                      "Report",
                      "Progress"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Document created, metadata updated, or current file version replaced.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentDetailResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid document creation payload or file.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "INVALID_DOCUMENT_PATCH": {
                    "summary": "Invalid document payload",
                    "value": {
                      "code": "INVALID_DOCUMENT_PATCH",
                      "message": "Invalid document patch."
                    }
                  },
                  "INVALID_DOCUMENT_FILE": {
                    "summary": "Invalid or missing document file",
                    "value": {
                      "code": "INVALID_DOCUMENT_FILE",
                      "message": "Document file is required."
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Referenced key or subKey was not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "KEY_NOT_FOUND": {
                    "summary": "KEY_NOT_FOUND",
                    "value": {
                      "code": "KEY_NOT_FOUND",
                      "message": "Document key not found."
                    }
                  },
                  "SUB_KEY_NOT_FOUND": {
                    "summary": "SUB_KEY_NOT_FOUND",
                    "value": {
                      "code": "SUB_KEY_NOT_FOUND",
                      "message": "Document sub key not found."
                    }
                  }
                }
              }
            }
          }
        },
        "summary": "Acquire or update generated document",
        "tags": [
          "Document keys"
        ]
      }
    },
    "/api/v1/document-keys/{keyType}/{key}/documents/{documentId}/file": {
      "get": {
        "description": "Scarica il file associato al documento.",
        "operationId": "DocumentKeysController_downloadDocumentFile",
        "parameters": [
          {
            "name": "keyType",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "example": "Project",
              "enum": [
                "Portfolio",
                "Program",
                "Project",
                "Activity",
                "Template",
                "Join"
              ],
              "description": "Tipo item MAC core compatibile con ItemType."
            },
            "description": "Tipo item MAC core. Valori compatibili con ItemType: Portfolio, Program, Project, Activity, Template, Join."
          },
          {
            "name": "key",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "example": "PRJ-001"
            },
            "description": "Identificativo dell item MAC core, equivalente a itemId."
          },
          {
            "name": "documentId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "pattern": "^DOC-[0-9]{3}$",
              "example": "DOC-001"
            },
            "description": "ID del documento nel formato DOC-001"
          }
        ],
        "responses": {
          "200": {
            "description": "File binario o testuale associato al documento.",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "INVALID_DOCUMENT_ID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "INVALID_DOCUMENT_ID": {
                    "summary": "INVALID_DOCUMENT_ID",
                    "value": {
                      "code": "INVALID_DOCUMENT_ID",
                      "message": "Invalid document id."
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "KEY_NOT_FOUND, DOCUMENT_NOT_FOUND or DOCUMENT_FILE_NOT_FOUND",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "KEY_NOT_FOUND": {
                    "summary": "KEY_NOT_FOUND",
                    "value": {
                      "code": "KEY_NOT_FOUND",
                      "message": "Document key not found."
                    }
                  },
                  "DOCUMENT_NOT_FOUND": {
                    "summary": "DOCUMENT_NOT_FOUND",
                    "value": {
                      "code": "DOCUMENT_NOT_FOUND",
                      "message": "Document not found."
                    }
                  },
                  "DOCUMENT_FILE_NOT_FOUND": {
                    "summary": "DOCUMENT_FILE_NOT_FOUND",
                    "value": {
                      "code": "DOCUMENT_FILE_NOT_FOUND",
                      "message": "Document file not found."
                    }
                  }
                }
              }
            }
          }
        },
        "summary": "Download document file by key",
        "tags": [
          "Document keys"
        ]
      }
    },
