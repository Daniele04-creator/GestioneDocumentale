      "UpdateDocumentRequest": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": {
            "type": "string",
            "example": "Nuovo titolo",
            "description": "Campo legacy: viene convertito in metadata.title."
          },
          "description": {
            "type": "string",
            "example": "Nuova descrizione",
            "description": "Campo legacy: viene convertito in metadata.description."
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "in_review",
              "approved"
            ],
            "example": "in_review"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "title": {
                "type": "string",
                "example": "Report avanzamento gennaio"
              },
              "description": {
                "type": "string",
                "example": "Documento generato da una funzione esterna"
              },
              "templateId": {
                "type": "string",
                "example": "TPL-REPORT"
              },
              "templateName": {
                "type": "string",
                "example": "Template report mensile"
              },
              "owner": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "id": {
                    "type": "string",
                    "example": "owner-001"
                  },
                  "name": {
                    "type": "string",
                    "example": "Francesca R"
                  },
                  "email": {
                    "type": "string",
                    "example": "francesca@example.test"
                  },
                  "source": {
                    "type": "string",
                    "example": "external-system"
                  }
                }
              },
              "source": {
                "type": "object",
                "additionalProperties": true,
                "example": {
                  "generatedBy": "template-service"
                }
              }
            },
            "description": "Patch parziale dei metadati descrittivi. Non puo contenere campi core come id, status, version, fileInfo, checksumSha256, keyType, key, subKey o documentKey.",
            "example": {
              "title": "Nuovo titolo",
              "description": "Nuova descrizione"
            }
          }
        }
      },
      "CreateDocumentRequest": {
        "type": "object",
        "required": [
          "file",
          "subKey",
          "documentKey"
        ],
        "properties": {
          "file": {
            "type": "string",
            "format": "binary",
            "description": "Documento finale prodotto da un modulo esterno e acquisito dal modulo documentale."
          },
          "subKey": {
            "type": "string",
            "example": "WP-001",
            "description": "WorkPackage.id del MAC core a cui collegare il documento."
          },
          "documentKey": {
            "type": "string",
            "maxLength": 150,
            "example": "TPL-REPORT-MENSILE-2026-01",
            "description": "Chiave logica del documento generato nel contesto keyType/key/subKey."
          },
          "templateId": {
            "type": "string",
            "maxLength": 150,
            "example": "TPL-REPORT-MENSILE",
            "description": "Campo legacy: viene salvato in metadata.templateId."
          },
          "templateName": {
            "type": "string",
            "maxLength": 200,
            "example": "Template report mensile",
            "description": "Campo legacy: viene salvato in metadata.templateName."
          },
          "title": {
            "type": "string",
            "example": "Report avanzamento",
            "description": "Campo legacy: se metadata non contiene title, viene usato come metadata.title."
          },
          "description": {
            "type": "string",
            "nullable": true,
            "example": "Documento prodotto da una funzione esterna",
            "description": "Campo legacy: viene salvato in metadata.description."
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "in_review",
              "approved"
            ],
            "default": "draft",
            "example": "draft"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "example": "Report"
            },
            "example": [
              "Report",
              "Progress"
            ]
          },
          "metadata": {
            "type": "string",
            "description": "JSON string con i metadati descrittivi del documento. Deve contenere almeno metadata.title. I campi legacy title/description/templateId/templateName restano supportati come fallback.",
            "example": "{\"title\":\"Report avanzamento\",\"description\":\"Documento prodotto da una funzione esterna\",\"templateId\":\"TPL-REPORT\",\"templateName\":\"Template report\",\"owner\":{\"id\":\"USR-123\",\"name\":\"Mario Rossi\",\"source\":\"external-user-service\"}}"
          }
        }
      },
      "DocumentMetadata": {
        "type": "object",
        "required": [
          "title"
        ],
        "additionalProperties": true,
        "properties": {
          "title": {
            "type": "string",
            "example": "Report avanzamento gennaio"
          },
          "description": {
            "type": "string",
            "example": "Documento generato da una funzione esterna"
          },
          "templateId": {
            "type": "string",
            "example": "TPL-REPORT"
          },
          "templateName": {
            "type": "string",
            "example": "Template report mensile"
          },
          "owner": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "id": {
                "type": "string",
                "example": "USR-123"
              },
              "name": {
                "type": "string",
                "example": "Mario Rossi"
              },
              "email": {
                "type": "string",
                "example": "francesca@example.test"
              },
              "source": {
                "type": "string",
                "example": "external-user-service"
              }
            },
            "description": "Snapshot opzionale di una Resource/owner proveniente da servizi MAC core o esterni. Il modulo documentale non valida ne gestisce owner locali."
          },
          "source": {
            "type": "object",
            "additionalProperties": true,
            "example": {
              "generatedBy": "template-service"
            }
          }
        }
      }
    }
  }
