    },
    "/api/v1/document-keys/{keyType}/{key}/documents": {
      "get": {
        "description": "Restituisce i documenti del contenitore documentale, raggruppati per subKey e filtrabili tramite query parameters.",
        "operationId": "DocumentKeysController_listDocuments",
        "parameters": [
          {
            "name": "search",
            "required": false,
            "in": "query",
            "schema": {
              "example": "srs"
            }
          },
          {
            "name": "status",
            "required": false,
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "draft",
                "in_review",
                "approved",
                "archived"
              ],
              "example": "approved"
            }
          },
          {
            "name": "tag",
            "required": false,
            "in": "query",
            "schema": {
              "example": "Architettura"
            }
          },
          {
            "name": "ownerId",
            "required": false,
            "in": "query",
            "schema": {
              "example": "owner-001"
            }
          },
          {
            "name": "subKey",
            "required": false,
            "in": "query",
            "schema": {
              "example": "PKG-001"
            }
          },
          {
            "name": "keyType",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "example": "project"
            },
            "description": "Tipo del contenitore documentale"
          },
          {
            "name": "key",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "example": "PRJ-001"
            },
            "description": "Identificativo del contenitore documentale"
          }
        ],
        "responses": {
          "200": {
            "description": "Document home returned.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentHomeResponse"
                }
              }
            }
          },
          "400": {
            "description": "INVALID_QUERY_PARAM",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "INVALID_QUERY_PARAM": {
                    "summary": "INVALID_QUERY_PARAM",
                    "value": {
                      "code": "INVALID_QUERY_PARAM",
                      "message": "Parametro query non valido."
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "KEY_NOT_FOUND",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "KEY_NOT_FOUND": {
                    "summary": "KEY_NOT_FOUND",
                    "value": {
                      "code": "KEY_NOT_FOUND",
                      "message": "Document key not found."
                    }
                  }
                }
              }
            }
          }
        },
        "summary": "List documents by key",
        "tags": [
          "Document keys"
        ]
      },
      "post": {
        "description": "Acquisisce un documento finale prodotto da un modulo esterno. Se documentKey non esiste nel contesto keyType/key/subKey crea un nuovo documento versione 1; se esiste e il checksum SHA-256 e uguale aggiorna solo i metadati; se esiste e il checksum cambia salva una nuova versione senza sovrascrivere i file precedenti.",
        "operationId": "DocumentKeysController_createDocument",
        "parameters": [
          {
            "name": "keyType",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "example": "project"
            },
            "description": "Tipo del contenitore documentale"
          },
          {
            "name": "key",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "example": "PRJ-001"
            },
            "description": "Identificativo del contenitore documentale"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/CreateDocumentRequest"
              },
              "examples": {
                "createDocument": {
                  "summary": "Acquire generated document",
                  "value": {
                    "file": "<binary file>",
                    "subKey": "PKG-001",
                    "documentKey": "TPL-REPORT-MENSILE-2026-01",
                    "templateId": "TPL-REPORT-MENSILE",
                    "templateName": "Template report mensile",
                    "title": "Report avanzamento",
                    "description": "Documento prodotto da una funzione esterna",
                    "ownerId": "owner-001",
                    "status": "draft",
                    "tags": [
                      "Report",
                      "Progress"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Document created, metadata updated, or new version registered.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentDetailResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid document creation payload or file.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "INVALID_DOCUMENT_PATCH": {
                    "summary": "Invalid document payload",
                    "value": {
                      "code": "INVALID_DOCUMENT_PATCH",
                      "message": "Invalid document patch."
                    }
                  },
                  "INVALID_DOCUMENT_FILE": {
                    "summary": "Invalid or missing document file",
                    "value": {
                      "code": "INVALID_DOCUMENT_FILE",
                      "message": "Document file is required."
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Referenced key, subKey or owner was not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "KEY_NOT_FOUND": {
                    "summary": "KEY_NOT_FOUND",
                    "value": {
                      "code": "KEY_NOT_FOUND",
                      "message": "Document key not found."
                    }
                  },
                  "SUB_KEY_NOT_FOUND": {
                    "summary": "SUB_KEY_NOT_FOUND",
                    "value": {
                      "code": "SUB_KEY_NOT_FOUND",
                      "message": "Document sub key not found."
                    }
                  },
                  "OWNER_NOT_FOUND": {
                    "summary": "OWNER_NOT_FOUND",
                    "value": {
                      "code": "OWNER_NOT_FOUND",
                      "message": "Document owner not found."
                    }
                  }
                }
              }
            }
          }
        },
        "summary": "Acquire or version generated document",
        "tags": [
          "Document keys"
        ]
      }
    },
    "/api/v1/document-keys/{keyType}/{key}/documents/{documentId}/file": {
      "get": {
        "description": "Scarica il file associato al documento.",
        "operationId": "DocumentKeysController_downloadDocumentFile",
        "parameters": [
          {
            "name": "keyType",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "example": "project"
            },
            "description": "Tipo del contenitore documentale"
          },
          {
            "name": "key",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "example": "PRJ-001"
            },
            "description": "Identificativo del contenitore documentale"
          },
          {
            "name": "documentId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string",
              "pattern": "^DOC-[0-9]{3}$",
              "example": "DOC-001"
            },
            "description": "ID del documento nel formato DOC-001"
          }
        ],
        "responses": {
          "200": {
            "description": "File binario o testuale associato al documento.",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "INVALID_DOCUMENT_ID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "INVALID_DOCUMENT_ID": {
                    "summary": "INVALID_DOCUMENT_ID",
                    "value": {
                      "code": "INVALID_DOCUMENT_ID",
                      "message": "Invalid document id."
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "KEY_NOT_FOUND, DOCUMENT_NOT_FOUND or DOCUMENT_FILE_NOT_FOUND",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "KEY_NOT_FOUND": {
                    "summary": "KEY_NOT_FOUND",
                    "value": {
                      "code": "KEY_NOT_FOUND",
                      "message": "Document key not found."
                    }
                  },
                  "DOCUMENT_NOT_FOUND": {
                    "summary": "DOCUMENT_NOT_FOUND",
                    "value": {
                      "code": "DOCUMENT_NOT_FOUND",
                      "message": "Document not found."
                    }
                  },
                  "DOCUMENT_FILE_NOT_FOUND": {
                    "summary": "DOCUMENT_FILE_NOT_FOUND",
                    "value": {
                      "code": "DOCUMENT_FILE_NOT_FOUND",
                      "message": "Document file not found."
                    }
                  }
                }
              }
            }
          }
        },
        "summary": "Download document file by key",
        "tags": [
          "Document keys"
        ]
      }
    },
