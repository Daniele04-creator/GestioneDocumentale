{
  "openapi": "3.0.0",
  "paths": {
    "/api/v1/health": {
      "get": {
        "description": "Verifica che il backend sia avviato.",
        "operationId": "HealthController_getHealth",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Backend is running.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        },
        "summary": "Health check",
        "tags": [
          "Health"
        ]
      }
    },
    "/api/v1/projects/{projectId}/documents": {
      "get": {
        "description": "Restituisce la home documentale del progetto, con documenti raggruppati per package e filtrabili tramite query parameters.",
        "operationId": "ProjectDocumentsController_listProjectDocuments",
        "parameters": [
          {
            "name": "search",
            "required": false,
            "in": "query",
            "schema": {
              "example": "srs"
            }
          },
          {
            "name": "status",
            "required": false,
            "in": "query",
            "schema": {
              "enum": [
                "draft",
                "in_review",
                "approved",
                "archived"
              ],
              "type": "string"
            }
          },
          {
            "name": "tag",
            "required": false,
            "in": "query",
            "schema": {
              "example": "Architettura"
            }
          },
          {
            "name": "ownerId",
            "required": false,
            "in": "query",
            "schema": {
              "example": "owner-001"
            }
          },
          {
            "name": "packageId",
            "required": false,
            "in": "query",
            "schema": {
              "example": "package-001"
            }
          },
          {
            "name": "projectId",
            "required": true,
            "in": "path",
            "description": "ID del progetto",
            "schema": {
              "example": "project-001"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Project document home returned.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentHomeResponse"
                }
              }
            }
          },
          "400": {
            "description": "INVALID_QUERY_PARAM",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "INVALID_QUERY_PARAM": {
                    "summary": "INVALID_QUERY_PARAM",
                    "value": {
                      "code": "INVALID_QUERY_PARAM",
                      "message": "Parametro query non valido."
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "PROJECT_NOT_FOUND",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "PROJECT_NOT_FOUND": {
                    "summary": "PROJECT_NOT_FOUND",
                    "value": {
                      "code": "PROJECT_NOT_FOUND",
                      "message": "Project not found."
                    }
                  }
                }
              }
            }
          }
        },
        "summary": "List project documents",
        "tags": [
          "Project documents"
        ]
      }
    },
    "/api/v1/projects/{projectId}/document-tree": {
      "get": {
        "description": "Restituisce una struttura leggera dei package del progetto, con conteggi e statusSummary, senza caricare i dettagli dei documenti.",
        "operationId": "ProjectDocumentsController_getProjectDocumentTree",
        "parameters": [
          {
            "name": "projectId",
            "required": true,
            "in": "path",
            "description": "ID del progetto",
            "style": "simple",
            "explode": false,
            "schema": {
              "example": "project-001"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Project document tree returned.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentTreeResponse"
                }
              }
            }
          },
          "404": {
            "description": "PROJECT_NOT_FOUND",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "PROJECT_NOT_FOUND": {
                    "summary": "PROJECT_NOT_FOUND",
                    "value": {
                      "code": "PROJECT_NOT_FOUND",
                      "message": "Project not found."
                    }
                  }
                }
              }
            }
          }
        },
        "summary": "Get project document tree",
        "tags": [
          "Project documents"
        ]
      }
    },
    "/api/v1/projects/{projectId}/documents/{documentId}/file": {
      "get": {
        "description": "Scarica il file associato al documento.",
        "operationId": "ProjectDocumentsController_downloadProjectDocumentFile",
        "parameters": [
          {
            "name": "documentId",
            "required": true,
            "in": "path",
            "description": "ID del documento nel formato DOC-001",
            "schema": {
              "type": "string",
              "pattern": "^DOC-[0-9]{3}$"
            }
          },
          {
            "name": "projectId",
            "required": true,
            "in": "path",
            "description": "ID del progetto",
            "schema": {
              "example": "project-001"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File binario o testuale associato al documento.",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "INVALID_DOCUMENT_ID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "INVALID_DOCUMENT_ID": {
                    "summary": "INVALID_DOCUMENT_ID",
                    "value": {
                      "code": "INVALID_DOCUMENT_ID",
                      "message": "Invalid document id."
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "PROJECT_NOT_FOUND, DOCUMENT_NOT_FOUND or DOCUMENT_FILE_NOT_FOUND",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "PROJECT_NOT_FOUND": {
                    "summary": "PROJECT_NOT_FOUND",
                    "value": {
                      "code": "PROJECT_NOT_FOUND",
                      "message": "Project not found."
                    }
                  },
                  "DOCUMENT_NOT_FOUND": {
                    "summary": "DOCUMENT_NOT_FOUND",
                    "value": {
                      "code": "DOCUMENT_NOT_FOUND",
                      "message": "Document not found."
                    }
                  },
                  "DOCUMENT_FILE_NOT_FOUND": {
                    "summary": "DOCUMENT_FILE_NOT_FOUND",
                    "value": {
                      "code": "DOCUMENT_FILE_NOT_FOUND",
                      "message": "Document file not found."
                    }
                  }
                }
              }
            }
          }
        },
        "summary": "Download project document file",
        "tags": [
          "Project documents"
        ]
      }
    },
    "/api/v1/projects/{projectId}/documents/{documentId}": {
      "get": {
        "description": "Restituisce il dettaglio di un documento appartenente al progetto indicato.",
        "operationId": "ProjectDocumentsController_getProjectDocumentById",
        "parameters": [
          {
            "name": "documentId",
            "required": true,
            "in": "path",
            "description": "ID del documento nel formato DOC-001",
            "schema": {
              "type": "string",
              "pattern": "^DOC-[0-9]{3}$"
            }
          },
          {
            "name": "projectId",
            "required": true,
            "in": "path",
            "description": "ID del progetto",
            "schema": {
              "example": "project-001"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Document detail returned.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentDetailResponse"
                }
              }
            }
          },
          "400": {
            "description": "INVALID_DOCUMENT_ID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "INVALID_DOCUMENT_ID": {
                    "summary": "INVALID_DOCUMENT_ID",
                    "value": {
                      "code": "INVALID_DOCUMENT_ID",
                      "message": "Invalid document id."
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "PROJECT_NOT_FOUND or DOCUMENT_NOT_FOUND",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "PROJECT_NOT_FOUND": {
                    "summary": "PROJECT_NOT_FOUND",
                    "value": {
                      "code": "PROJECT_NOT_FOUND",
                      "message": "Project not found."
                    }
                  },
                  "DOCUMENT_NOT_FOUND": {
                    "summary": "DOCUMENT_NOT_FOUND",
                    "value": {
                      "code": "DOCUMENT_NOT_FOUND",
                      "message": "Document not found."
                    }
                  }
                }
              }
            }
          }
        },
        "summary": "Get project document by id",
        "tags": [
          "Project documents"
        ]
      },
      "patch": {
        "description": "Aggiorna i campi modificabili di un documento non archiviato.",
        "operationId": "ProjectDocumentsController_updateProjectDocument",
        "parameters": [
          {
            "name": "documentId",
            "required": true,
            "in": "path",
            "description": "ID del documento nel formato DOC-001",
            "schema": {
              "type": "string",
              "pattern": "^DOC-[0-9]{3}$"
            }
          },
          {
            "name": "projectId",
            "required": true,
            "in": "path",
            "description": "ID del progetto",
            "schema": {
              "example": "project-001"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateDocumentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated document detail returned.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentDetailResponse"
                }
              }
            }
          },
          "400": {
            "description": "INVALID_DOCUMENT_ID or INVALID_DOCUMENT_PATCH",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "INVALID_DOCUMENT_ID": {
                    "summary": "INVALID_DOCUMENT_ID",
                    "value": {
                      "code": "INVALID_DOCUMENT_ID",
                      "message": "Invalid document id."
                    }
                  },
                  "INVALID_DOCUMENT_PATCH": {
                    "summary": "INVALID_DOCUMENT_PATCH",
                    "value": {
                      "code": "INVALID_DOCUMENT_PATCH",
                      "message": "Invalid document patch."
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "PROJECT_NOT_FOUND or DOCUMENT_NOT_FOUND",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "PROJECT_NOT_FOUND": {
                    "summary": "PROJECT_NOT_FOUND",
                    "value": {
                      "code": "PROJECT_NOT_FOUND",
                      "message": "Project not found."
                    }
                  },
                  "DOCUMENT_NOT_FOUND": {
                    "summary": "DOCUMENT_NOT_FOUND",
                    "value": {
                      "code": "DOCUMENT_NOT_FOUND",
                      "message": "Document not found."
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "DOCUMENT_ARCHIVED",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "DOCUMENT_ARCHIVED": {
                    "summary": "DOCUMENT_ARCHIVED",
                    "value": {
                      "code": "DOCUMENT_ARCHIVED",
                      "message": "Il documento archiviato non può essere modificato."
                    }
                  }
                }
              }
            }
          }
        },
        "summary": "Update project document",
        "tags": [
          "Project documents"
        ]
      },
      "delete": {
        "description": "Archivia logicamente il documento impostando status archived e archivedAt.",
        "operationId": "ProjectDocumentsController_archiveProjectDocument",
        "parameters": [
          {
            "name": "documentId",
            "required": true,
            "in": "path",
            "description": "ID del documento nel formato DOC-001",
            "schema": {
              "type": "string",
              "pattern": "^DOC-[0-9]{3}$"
            }
          },
          {
            "name": "projectId",
            "required": true,
            "in": "path",
            "description": "ID del progetto",
            "schema": {
              "example": "project-001"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Archived document detail returned.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentDetailResponse"
                }
              }
            }
          },
          "400": {
            "description": "INVALID_DOCUMENT_ID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "INVALID_DOCUMENT_ID": {
                    "summary": "INVALID_DOCUMENT_ID",
                    "value": {
                      "code": "INVALID_DOCUMENT_ID",
                      "message": "Invalid document id."
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "PROJECT_NOT_FOUND or DOCUMENT_NOT_FOUND",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "examples": {
                  "PROJECT_NOT_FOUND": {
                    "summary": "PROJECT_NOT_FOUND",
                    "value": {
                      "code": "PROJECT_NOT_FOUND",
                      "message": "Project not found."
                    }
                  },
                  "DOCUMENT_NOT_FOUND": {
                    "summary": "DOCUMENT_NOT_FOUND",
                    "value": {
                      "code": "DOCUMENT_NOT_FOUND",
                      "message": "Document not found."
                    }
                  }
                }
              }
            }
          }
        },
        "summary": "Archive project document",
        "tags": [
          "Project documents"
        ]
      }
    }
  },
  "info": {
    "title": "Management as Code Documents API",
    "description": "API del modulo documentale project-scoped di Management as Code.",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "Project documents",
      "description": ""
    },
    {
      "name": "Health",
      "description": ""
    }
  ],
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development server"
    }
  ],
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "required": [
          "status",
          "timestamp"
        ],
        "properties": {
          "status": {
            "type": "string",
            "example": "ok"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "nullable": false,
            "example": "2026-01-01T10:00:00.000Z"
          }
        }
      },
      "ApiError": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string",
            "example": "ERROR_CODE"
          },
          "message": {
            "type": "string",
            "example": "Clear error message."
          }
        }
      },
      "DocumentStatusSummary": {
        "type": "object",
        "required": [
          "draft",
          "in_review",
          "approved",
          "archived"
        ],
        "properties": {
          "draft": {
            "type": "integer",
            "minimum": 0,
            "example": 0
          },
          "in_review": {
            "type": "integer",
            "minimum": 0,
            "example": 0
          },
          "approved": {
            "type": "integer",
            "minimum": 0,
            "example": 1
          },
          "archived": {
            "type": "integer",
            "minimum": 0,
            "example": 0
          }
        }
      },
      "DocumentTag": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "example": "Architettura"
          }
        }
      },
      "DocumentOwner": {
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "owner-001"
          },
          "name": {
            "type": "string",
            "example": "Francesca R"
          }
        }
      },
      "ProjectRef": {
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "project-001"
          },
          "name": {
            "type": "string",
            "example": "Management as Code Demo"
          }
        }
      },
      "PackageRef": {
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "package-001"
          },
          "name": {
            "type": "string",
            "example": "Documentazione requisiti"
          }
        }
      },
      "ParentPackageRef": {
        "type": "object",
        "nullable": true,
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "package-001"
          },
          "name": {
            "type": "string",
            "example": "Documentazione requisiti"
          }
        },
        "example": null
      },
      "FileInfo": {
        "type": "object",
        "required": [
          "fileName",
          "mimeType",
          "sizeBytes"
        ],
        "properties": {
          "fileName": {
            "type": "string",
            "example": "project-plan.txt"
          },
          "mimeType": {
            "type": "string",
            "example": "text/plain"
          },
          "sizeBytes": {
            "type": "integer",
            "minimum": 0,
            "example": 136
          }
        }
      },
      "DocumentListItem": {
        "type": "object",
        "required": [
          "id",
          "title",
          "status",
          "version",
          "updatedAt",
          "owner",
          "tags"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "DOC-001"
          },
          "title": {
            "type": "string",
            "example": "Specifica SRS"
          },
          "description": {
            "type": "string",
            "example": "Documento dei requisiti software"
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "in_review",
              "approved",
              "archived"
            ],
            "example": "approved"
          },
          "version": {
            "type": "integer",
            "minimum": 1,
            "example": 1
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "example": null
          },
          "owner": {
            "$ref": "#/components/schemas/DocumentOwner"
          },
          "tags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DocumentTag"
            }
          }
        }
      },
      "DocumentDetail": {
        "type": "object",
        "required": [
          "id",
          "title",
          "status",
          "project",
          "package",
          "parentPackage",
          "owner",
          "fileInfo",
          "version",
          "createdAt",
          "updatedAt",
          "archivedAt",
          "tags"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "DOC-001"
          },
          "title": {
            "type": "string",
            "example": "Specifica SRS"
          },
          "description": {
            "type": "string",
            "example": "Documento dei requisiti software"
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "in_review",
              "approved",
              "archived"
            ],
            "example": "approved"
          },
          "project": {
            "$ref": "#/components/schemas/ProjectRef"
          },
          "package": {
            "$ref": "#/components/schemas/PackageRef"
          },
          "parentPackage": {
            "$ref": "#/components/schemas/ParentPackageRef"
          },
          "owner": {
            "$ref": "#/components/schemas/DocumentOwner"
          },
          "fileInfo": {
            "$ref": "#/components/schemas/FileInfo"
          },
          "version": {
            "type": "integer",
            "minimum": 1,
            "example": 1
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "nullable": false,
            "example": "2026-01-01T10:00:00.000Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "example": null
          },
          "archivedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "example": null
          },
          "tags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DocumentTag"
            }
          }
        }
      },
      "DocumentDetailResponse": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/DocumentDetail"
          }
        }
      },
      "DocumentPackageGroup": {
        "type": "object",
        "required": [
          "project",
          "id",
          "name",
          "parentPackage",
          "documentCount",
          "statusSummary",
          "documents"
        ],
        "properties": {
          "project": {
            "$ref": "#/components/schemas/ProjectRef"
          },
          "id": {
            "type": "string",
            "example": "package-001"
          },
          "name": {
            "type": "string",
            "example": "Documentazione requisiti"
          },
          "parentPackage": {
            "$ref": "#/components/schemas/ParentPackageRef"
          },
          "documentCount": {
            "type": "integer",
            "minimum": 0,
            "example": 2
          },
          "statusSummary": {
            "$ref": "#/components/schemas/DocumentStatusSummary"
          },
          "documents": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DocumentListItem"
            }
          }
        }
      },
      "DocumentHomeMeta": {
        "type": "object",
        "required": [
          "totalPackages",
          "totalDocuments"
        ],
        "properties": {
          "totalPackages": {
            "type": "integer",
            "minimum": 0,
            "example": 1
          },
          "totalDocuments": {
            "type": "integer",
            "minimum": 0,
            "example": 2
          }
        }
      },
      "DocumentHomeResponse": {
        "type": "object",
        "required": [
          "data",
          "meta"
        ],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DocumentPackageGroup"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/DocumentHomeMeta"
          }
        }
      },
      "DocumentTreePackage": {
        "type": "object",
        "required": [
          "id",
          "name",
          "parentPackage",
          "documentCount",
          "statusSummary"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "package-001"
          },
          "name": {
            "type": "string",
            "example": "Documentazione requisiti"
          },
          "parentPackage": {
            "$ref": "#/components/schemas/ParentPackageRef"
          },
          "documentCount": {
            "type": "integer",
            "minimum": 0,
            "example": 2
          },
          "statusSummary": {
            "$ref": "#/components/schemas/DocumentStatusSummary"
          }
        }
      },
      "DocumentTreeMeta": {
        "type": "object",
        "required": [
          "totalPackages",
          "totalDocuments"
        ],
        "properties": {
          "totalPackages": {
            "type": "integer",
            "minimum": 0,
            "example": 1
          },
          "totalDocuments": {
            "type": "integer",
            "minimum": 0,
            "example": 2
          }
        }
      },
      "DocumentTreeResponse": {
        "type": "object",
        "required": [
          "data",
          "meta"
        ],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DocumentTreePackage"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/DocumentTreeMeta"
          }
        }
      },
      "UpdateDocumentRequest": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": {
            "type": "string",
            "example": "Nuovo titolo"
          },
          "description": {
            "type": "string",
            "example": "Nuova descrizione"
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "in_review",
              "approved"
            ],
            "example": "in_review"
          }
        }
      }
    }
  }
}
