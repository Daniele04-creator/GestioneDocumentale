      "UpdateDocumentRequest": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": {
            "type": "string",
            "example": "Nuovo titolo"
          },
          "description": {
            "type": "string",
            "example": "Nuova descrizione"
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "in_review",
              "approved"
            ],
            "example": "in_review"
          }
        }
      },
      "CreateDocumentRequest": {
        "type": "object",
        "required": [
          "file",
          "subKey",
          "title",
          "ownerId",
          "documentKey"
        ],
        "properties": {
          "file": {
            "type": "string",
            "format": "binary",
            "description": "Documento finale prodotto da un modulo esterno e acquisito dal modulo documentale."
          },
          "subKey": {
            "type": "string",
            "example": "PKG-001"
          },
          "documentKey": {
            "type": "string",
            "maxLength": 150,
            "example": "TPL-REPORT-MENSILE-2026-01",
            "description": "Chiave logica del documento generato nel contesto keyType/key/subKey."
          },
          "templateId": {
            "type": "string",
            "maxLength": 150,
            "example": "TPL-REPORT-MENSILE",
            "description": "Template sorgente usato dal modulo esterno per generare il documento."
          },
          "templateName": {
            "type": "string",
            "maxLength": 200,
            "example": "Template report mensile"
          },
          "title": {
            "type": "string",
            "example": "Report avanzamento"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "example": "Documento prodotto da una funzione esterna"
          },
          "ownerId": {
            "type": "string",
            "example": "owner-001"
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "in_review",
              "approved"
            ],
            "default": "draft",
            "example": "draft"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "example": "Report"
            },
            "example": [
              "Report",
              "Progress"
            ]
          }
        }
      },
      "DocumentVersion": {
        "type": "object",
        "required": [
          "documentId",
          "version",
          "fileInfo",
          "checksumSha256",
          "createdAt"
        ],
        "properties": {
          "documentId": {
            "type": "string",
            "example": "DOC-020"
          },
          "version": {
            "type": "integer",
            "minimum": 1,
            "example": 1
