          "checksumSha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$",
            "example": "3286318d7c501f31d48312f3226a78acd7619e716313ede1548047b476cdce3e"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-01-01T10:00:00.000Z"
          }
